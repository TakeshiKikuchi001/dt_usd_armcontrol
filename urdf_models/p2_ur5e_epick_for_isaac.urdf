<?xml version="1.0"?>
<robot name="p2_ur5e_epick">

  <!-- ========================================= -->
  <!-- UR5e ARM SECTION                          -->
  <!-- ========================================= -->
  
  <link name="world"/>
  
  <!-- Base Link -->
  <link name="base_link"/>
  <link name="base_link_inertia">
    <visual>
      <origin rpy="0.0 0.0 3.141592653589793" xyz="0.0 0.0 0.0"/>
