    </inertial>
  </link>

  <!-- Shoulder Link -->
  <link name="shoulder_link">
    <visual>
      <origin rpy="0.0 0.0 3.141592653589793" xyz="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/visual/shoulder.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0.0 0.0 3.141592653589793" xyz="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/collision/shoulder.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="3.761"/>
      <origin rpy="1.570796326794897 0 0" xyz="0.0 -0.00193 -0.02561"/>
      <inertia ixx="0.0070021" ixy="7.3e-07" ixz="-1.053e-05" iyy="0.00648091" iyz="0.00049994" izz="0.00657286"/>
    </inertial>
  </link>

  <!-- Upper Arm Link -->
  <link name="upper_arm_link">
    <visual>
      <origin rpy="1.5707963267948966 0.0 -1.5707963267948966" xyz="0.0 0.0 0.138"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/visual/upperarm.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0.0 -1.5707963267948966" xyz="0.0 0.0 0.138"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/collision/upperarm.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="8.058"/>
      <origin rpy="0 0 0" xyz="-0.2125 0.0 0.11336"/>
      <inertia ixx="0.01505885" ixy="-5.4e-05" ixz="5.63e-06" iyy="0.33388086" iyz="-1.81e-06" izz="0.33247207"/>
    </inertial>
  </link>

  <!-- Forearm Link -->
  <link name="forearm_link">
    <visual>
      <origin rpy="1.5707963267948966 0.0 -1.5707963267948966" xyz="0.0 0.0 0.007"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/visual/forearm.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0.0 -1.5707963267948966" xyz="0.0 0.0 0.007"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/collision/forearm.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.846"/>
      <origin rpy="0 0 0" xyz="-0.2422 0.0 0.0265"/>
      <inertia ixx="0.00399632" ixy="-1.365e-05" ixz="0.00137272" iyy="0.07879254" iyz="-6.6e-06" izz="0.0784851"/>
    </inertial>
  </link>

  <!-- Wrist 1 Link -->
  <link name="wrist_1_link">
    <visual>
      <origin rpy="1.5707963267948966 0.0 0.0" xyz="0.0 0.0 -0.127"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/visual/wrist1.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0.0 0.0" xyz="0.0 0.0 -0.127"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/collision/wrist1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.37"/>
      <origin rpy="1.570796326794897 0 0" xyz="0.0 -0.01634 -0.0018"/>
      <inertia ixx="0.00165491" ixy="-2.82e-06" ixz="-4.38e-06" iyy="0.00135962" iyz="0.00010157" izz="0.00126279"/>
    </inertial>
  </link>

  <!-- Wrist 2 Link -->
  <link name="wrist_2_link">
    <visual>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 -0.0997"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/visual/wrist2.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 -0.0997"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/collision/wrist2.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.3"/>
      <origin rpy="-1.570796326794897 0 0" xyz="0.0 0.01634 -0.0018"/>
      <inertia ixx="0.00135617" ixy="-2.74e-06" ixz="4.44e-06" iyy="0.00127827" iyz="-5.048e-05" izz="0.00096614"/>
    </inertial>
  </link>

  <!-- Wrist 3 Link -->
  <link name="wrist_3_link">
    <visual>
      <origin rpy="1.5707963267948966 0.0 0.0" xyz="0.0 0.0 -0.0989"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/visual/wrist3.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0.0 0.0" xyz="0.0 0.0 -0.0989"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/ur5e/collision/wrist3.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.365"/>
      <origin rpy="0 0 0" xyz="0.0 0.0 -0.001159"/>
      <inertia ixx="0.00018694" ixy="6e-08" ixz="-1.7e-07" iyy="0.00018908" iyz="-9.2e-07" izz="0.00025756"/>
    </inertial>
  </link>

  <!-- ========================================= -->
  <!-- UR5e JOINTS                               -->
  <!-- ========================================= -->
  
  <joint name="base_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <joint name="base_link-base_link_inertia" type="fixed">
    <parent link="base_link"/>
    <child link="base_link_inertia"/>
    <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
  </joint>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link_inertia"/>
    <child link="shoulder_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.1625"/>
    <axis xyz="0 0 1"/>
    <limit effort="150.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin rpy="1.570796327 0 0" xyz="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="150.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin rpy="0 0 0" xyz="-0.425 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="150.0" lower="-3.141592653589793" upper="3.141592653589793" velocity="3.141592653589793"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_1_link"/>
    <origin rpy="0 0 0" xyz="-0.3922 0 0.1333"/>
    <axis xyz="0 0 1"/>
    <limit effort="28.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_1_link"/>
    <child link="wrist_2_link"/>
    <origin rpy="1.570796327 0 0" xyz="0 -0.0997 -2.044881182297852e-11"/>
    <axis xyz="0 0 1"/>
    <limit effort="28.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <joint name="wrist_3_joint" type="revolute">
    <parent link="wrist_2_link"/>
    <child link="wrist_3_link"/>
    <origin rpy="1.570796326589793 3.141592653589793 3.141592653589793" xyz="0 0.0996 -2.042830148012698e-11"/>
    <axis xyz="0 0 1"/>
    <limit effort="28.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <!-- Additional UR frames -->
  <link name="ft_frame"/>
  <joint name="wrist_3_link-ft_frame" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="ft_frame"/>
    <origin rpy="3.141592653589793 0 0" xyz="0 0 0"/>
  </joint>

  <link name="base"/>
  <joint name="base_link-base_fixed_joint" type="fixed">
    <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>

  <link name="flange"/>
  <joint name="wrist_3-flange" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="flange"/>
    <origin rpy="0 -1.5707963267948966 -1.5707963267948966" xyz="0 0 0"/>
  </joint>

  <link name="tool0"/>
  <joint name="flange-tool0" type="fixed">
    <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0 0 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>

  <!-- ========================================= -->
  <!-- EPICK GRIPPER SECTION                     -->
  <!-- ========================================= -->
  
  <!-- Connection joint: UR5e tool0 to EPick base -->
  <joint name="tool0_to_gripper" type="fixed">
    <parent link="tool0"/>
    <child link="epick_base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <!-- ros2_control for EPick -->
  <ros2_control name="epick_driver_ros2_control" type="system">
    <hardware>
      <plugin>epick_driver/EpickGripperHardwareInterface</plugin>
      <param name="usb_port">/dev/ttyUSB0</param>
      <param name="baud_rate">115200</param>
      <param name="timeout">0.2</param>
      <param name="use_dummy">False</param>
      <param name="slave_address">0x9</param>
      <param name="mode">AdvancedMode</param>
      <param name="grip_max_vacuum_pressure">-60</param>
      <param name="grip_min_vacuum_pressure">-10</param>
      <param name="grip_timeout">25.0</param>
      <param name="release_timeout">2.0</param>
    </hardware>
    <gpio name="gripper">
      <command_interface name="grip_cmd"/>
      <state_interface name="grip_cmd"/>
      <state_interface name="object_detection_status"/>
    </gpio>
    <joint name="gripper">
      <state_interface name="position"/>
    </joint>
  </ros2_control>

  <!-- Base Link -->
  <link name="epick_base_link"/>

  <!-- EPick Body -->
  <link name="epick_body">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 -0.05115"/>
      <geometry>
        <mesh filename="/home/nbdrobot/ros2_ws/src/merge/mesh/epick/visual/epick_body.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="epick_gray">
        <color rgba="0.25 0.25 0.25 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1023" radius="0.044"/>
      </geometry>
    </collision>
  </link>

  <joint name="epick_base_link_to_epick_body" type="fixed">
    <parent link="epick_base_link"/>
    <child link="epick_body"/>
    <origin rpy="0 0 0" xyz="0 0 0.05115"/>
  </joint>

  <!-- Suction Cup -->
  <link name="epick_suction_cup">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.015" radius="0.012"/>
      </geometry>
      <material name="">
        <color rgba="0.25 0.25 0.25 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.015" radius="0.012"/>
      </geometry>
    </collision>
  </link>

  <joint name="epick_body_to_epick_suction_cup" type="fixed">
    <parent link="epick_body"/>
    <child link="epick_suction_cup"/>
    <origin rpy="0 0 0" xyz="0 0 0.05865"/>
  </joint>

  <!-- TIP Frame -->
  <link name="epick_tip"/>
  <joint name="epick_suction_cup_to_epick_tip" type="fixed">
    <parent link="epick_suction_cup"/>
    <child link="epick_tip"/>
    <origin rpy="0 0 0" xyz="0 0 0.0075"/>
  </joint>

  <!-- TCP Frame -->
  <link name="epick_tcp"/>
  <joint name="epick_tip_to_epick_tcp" type="fixed">
    <parent link="epick_tip"/>
    <child link="epick_tcp"/>
    <origin rpy="0 0 0" xyz="0 0 -0.0"/>
  </joint>

  <!-- Vacuum State (for MoveIt) -->
  <link name="epick_vacuum_state"/>
  <joint name="gripper" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="epick_tcp"/>
    <child link="epick_vacuum_state"/>
    <limit effort="30" lower="0.0" upper="1.0" velocity="1.0"/>
  </joint>

</robot>
